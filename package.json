{
  "name": "@dataforxyz/agent-intercom-orchestrator",
  "version": "0.10.0",
  "description": "Pi extension for creating and managing independent Agent Intercom coworkers across Pi, Codex, Claude Code, and OpenCode",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "agent-intercom-fleet": "src/agent-fleet-cli.mjs",
    "agent-intercom-access": "src/agent-intercom-access.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dataforxyz/agent-intercom-orchestrator.git"
  },
  "homepage": "https://github.com/dataforxyz/agent-intercom-orchestrator#readme",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agents",
    "agent-intercom",
    "orchestration",
    "codex",
    "claude-code",
    "opencode"
  ],
  "files": [
    "src/**/*.ts",
    "src/**/*.mjs",
    "src/guard-bin/git",
    "src/guard-bin/gh",
    "src/guard-bin/tea",
    "skills/**/*",
    "examples/**/*",
    "docs/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "COPYRIGHT",
    "LICENSE_TRANSITION.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@dataforxyz/agent-intercom-core": "git+https://github.com/dataforxyz/agent-intercom-core.git#cb5d2212912db0cd8abbb16ab08e4b539424a05d"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@types/node": "^22.15.0",
    "typebox": "^1.1.24",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
